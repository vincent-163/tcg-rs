####################################################################
# aarch64.Ofast.tcgrs.cfg
# AArch64 cross-compiled benchmarks run through tcg-rs binary translator
#####################################################################

tune          = base
output_format = all,screen
reportable    = 0
teeout        = yes
teerunout     = yes
hw_avail      = Feb-2026
sw_avail      = Feb-2026
sw_other      = None
sw_base_ptrsize = 64-bit
license_num   = 999

## HW config
hw_cpu_name  = 12700k
hw_model     = 12700k desktop
hw_cpu_mhz   = 50000
hw_nchips    = 1
hw_ncores    = 8
hw_ncoresperchip= 8
hw_nthreads  = 1
hw_nthreadspercore = 1
hw_ocache    = None
hw_ncpuorder = 1 chips
hw_parallel  = no
hw_pcache    = None
hw_scache    = None
hw_tcache    = None
hw_memory    = 16 GB

## SW config
sw_os        = Ubuntu 20.04
sw_file      = ext4
sw_state     = runlevel 3
sw_compiler  = gcc , g++ & gfortran

makeflags    = -j16
ext           = aarch64.Ofast.tcgrs.20260320170154.jit

use_submit_for_speed = 1
SPEC = $SPEC
submit = TCG_RS=/data/Sync/all/projects/2026-02-11-cc-work/2026-03-tcg-rs/target/release/tcg-aarch64 /data/Sync/all/projects/2026-02-11-cc-work/2026-03-tcg-rs/tools/spec/submit-tcgrs-mode.sh -- $command

#####################################################################
# Compiler selection
#####################################################################
CC           = aarch64-none-linux-gnu-gcc
CXX          = aarch64-none-linux-gnu-g++
FC           = aarch64-none-linux-gnu-gfortran

#####################################################################
# Optimization
#####################################################################
default=peak=default=default:

default=base=default=default:
COPTIMIZE    = -Ofast -static -fsigned-char
CXXOPTIMIZE  = -Ofast -static -fsigned-char
FOPTIMIZE    = -Ofast -static -fallow-argument-mismatch -fno-stack-arrays

#####################################################################
# 32/64 bit Portability Flags
#####################################################################

default=base=default=default:
PORTABILITY = -DSPEC_CPU_LP64

450.soplex:
srcalt = getline_test
CXXPORTABILITY = -DSPEC_GETLINE_TEST

#####################################################################
# Portability Flags - INT
#####################################################################

400.perlbench=default=default=default:
CPORTABILITY= -DSPEC_CPU_LINUX_X64 -fgnu89-inline

462.libquantum=default=default=default:
CPORTABILITY= -DSPEC_CPU_LINUX

447.dealII=default=default=default:
CXXPORTABILITY= -DSPEC_CPU_LINUX_X64 -include cstdlib -include cstring -include cstddef -DBOOST_NO_AUTO_PTR -fpermissive

483.xalancbmk=default=default=default:
CXXPORTABILITY= -DSPEC_CPU_LINUX -include cstdlib -include cstring

416.gamess=default=default=default:
FPORTABILITY = -std=legacy
srcalt=common

481.wrf=default=default=default:
CPORTABILITY = -DSPEC_CPU_CASE_FLAG -DSPEC_CPU_LINUX

